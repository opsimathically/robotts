{
  "name": "robotts",
  "version": "0.7.0",
  "description": "Linux desktop automation and targeting for Node.js and TypeScript.",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.mjs"
    }
  },
  "scripts": {
    "test": "jasmine test/**/*.js",
    "test-keyboard": "node test/keyboard.js",
    "install": "node-gyp rebuild",
    "install-debug": "node-gyp rebuild --debug",
    "build": "node-gyp rebuild",
    "rebuild": "node-gyp rebuild"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opsimathically/robotts.git"
  },
  "keywords": [
    "Automation",
    "GUI",
    "mouse",
    "keyboard",
    "screenshot",
    "image",
    "pixel",
    "desktop",
    "robotts",
    "screen",
    "recognition",
    "autohotkey",
    "machine",
    "learning",
    "color"
  ],
  "author": "Jason Stallings",
  "license": "MIT",
  "gypfile": true,
  "engines": {
    "node": ">=22"
  },
  "binary": {
    "napi_versions": [
      3
    ]
  },
  "bugs": {
    "url": "https://github.com/opsimathically/robotts/issues"
  },
  "homepage": "https://github.com/opsimathically/robotts",
  "dependencies": {
    "node-addon-api": "^4.2.0"
  },
  "devDependencies": {
    "jasmine": "^2.99.0",
    "node-gyp": "^12.2.0",
    "tape": "^4.8.0"
  }
}
